<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_approval_center" model="ir.module.category">
        <field name="name">ADEC SOL Approval Center</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_approval_user" model="res.groups">
        <field name="name">Approval User</field>
        <field name="category_id" ref="module_category_approval_center"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_approval_approver" model="res.groups">
        <field name="name">Approval Approver</field>
        <field name="category_id" ref="module_category_approval_center"/>
        <field name="implied_ids" eval="[(4, ref('approval_center.group_approval_user'))]"/>
    </record>

    <!--
        FIX [Technical]: Phân quyền rõ ràng hơn cho approval.request:
        - User thường: đọc tất cả + tạo mới (để submit) + sửa request của chính mình
        - Approver: đọc + sửa request mà mình là approver
        - Approver: unlink request của mình hoặc đã cancelled
    -->

    <!-- User: đọc tất cả request (để xem trạng thái record mình submit) -->
    <record id="rule_approval_request_read_all" model="ir.rule">
        <field name="name">Approval Request: read all</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
        <field name="groups" eval="[(4, ref('approval_center.group_approval_user'))]"/>
    </record>

    <!-- User: chỉ sửa/cancel request do chính mình tạo -->
    <record id="rule_approval_request_write_own" model="ir.rule">
        <field name="name">Approval Request: write own requests</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[('requester_id', '=', user.id)]</field>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="groups" eval="[(4, ref('approval_center.group_approval_user'))]"/>
    </record>

    <!-- Approver: đọc + sửa request mà mình là approver -->
    <record id="rule_approval_request_write_approver" model="ir.rule">
        <field name="name">Approval Request: approver can write</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[('approver_ids', 'in', [user.id])]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
        <field name="groups" eval="[(4, ref('approval_center.group_approval_approver'))]"/>
    </record>
</odoo>
